# ==============================================
# Watery — 环境变量模板
# 复制此文件为 .env 并填写真实值
# ==============================================

# ---- 必填：火山引擎 Volcengine ----
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# ---- 可选：Gemini ----
GEMINI_API_KEY=

# ---- 可选：ms-agent deep_research 搜索引擎 ----
# 不填写则默认使用 arxiv（仅学术论文，免费无限制）
# EXA 提供高质量网络搜索，推荐配置（注册即有免费额度）：https://exa.ai
EXA_API_KEY=
# SerpAPI 提供 Google 搜索结果（EXA 的备选）：https://serpapi.com
SERPAPI_API_KEY=

# ---- 可选：ModelScope ----
MODELSCOPE_API_KEY=

# ---- 可选：代理订阅（Clash）----
SUBSCRIPTION_URL=
PROXY_REGION_FILTER=美国|US
